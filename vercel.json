{
  "redirects": [
    {
      "source": "https://pachislot-setting.com/:path*",
      "destination": "https://www.pachislot-setting.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}